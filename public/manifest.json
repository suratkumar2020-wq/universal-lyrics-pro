{
  "manifest_version": 3,
  "name": "Universal Lyrics Pro",
  "action": {
    "theme_color": "#000000"
  },
  "version": "1.0.0",
  "description": "AI-powered real-time lyrics for music platforms.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://*.spotify.com/*",
    "*://*.youtube.com/*",
    "*://*.jiosaavn.com/*",
    "https://lrclib.net/*"
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.spotify.com/*",
        "*://*.youtube.com/*",
        "*://*.jiosaavn.com/*"
      ],
      "js": ["content.js"]
    }
  ]
  
}
